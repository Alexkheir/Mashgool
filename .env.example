# ─── Mashgool — root environment variables ───────────────────────────────────
# Copy this file to `.env` in the repository root:  cp .env.example .env
# docker-compose.yml reads this file automatically — no manual export needed.
# The real .env is gitignored and must NEVER be committed.

# ─── Local PostgreSQL (db service in docker-compose.yml) ─────────────────────
# Database name created on first startup
POSTGRES_DB=mashgool
# Database superuser name
POSTGRES_USER=postgres
# Database password — fine as-is for local dev, NEVER reuse in production
POSTGRES_PASSWORD=postgres

# ─── Web (Next.js) ────────────────────────────────────────────────────────────
# Base URL the BROWSER uses to reach the Express API
NEXT_PUBLIC_API_URL=http://localhost:4000

# ─── Auth (Feature 7) ─────────────────────────────────────────────────────────
# docker-compose.yml has dev defaults for all of these, so the stack boots
# without them. Override here for real Google sign-in.
#
# Session JWT secret — generate one with:  openssl rand -base64 48
# JWT_SECRET=
# Google OAuth 2.0 credentials from the Google Cloud Console
# (APIs & Services → Credentials → OAuth client ID → Web application).
# Authorized redirect URI must be http://localhost:4000/api/v1/auth/google/callback
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
