# ─── Mashgool — root environment variables ───────────────────────────────────
# Copy this file to `.env` in the repository root:  cp .env.example .env
# docker-compose.yml reads this file automatically — no manual export needed.
# The real .env is gitignored and must NEVER be committed.

# ─── Local PostgreSQL (db service in docker-compose.yml) ─────────────────────
# Database name created on first startup
POSTGRES_DB=mashgool
# Database superuser name
POSTGRES_USER=postgres
# Database password — fine as-is for local dev, NEVER reuse in production
POSTGRES_PASSWORD=postgres

# ─── Web (Next.js) ────────────────────────────────────────────────────────────
# Base URL the BROWSER uses to reach the Express API
NEXT_PUBLIC_API_URL=http://localhost:4000
