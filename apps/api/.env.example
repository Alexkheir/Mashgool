# ─── Mashgool API — environment variables ────────────────────────────────────
# Copy to `.env` for running the API (or Prisma CLI) outside Docker. Inside
# Docker these are provided by docker-compose.yml.

# Port the Express API listens on
PORT=4000

# Database — from the HOST, Postgres is reachable on localhost:5432 (the port
# the db container publishes). Inside Docker the host is `db`, not localhost;
# that value is set by docker-compose.yml, so a container never reads this file.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/mashgool"

# ─── Auth (Feature 7) ─────────────────────────────────────────────────────────
# Session JWT — secret must be at least 32 chars (openssl rand -base64 48).
JWT_SECRET="change-me-to-a-long-random-string-at-least-32-chars"
JWT_EXPIRES_IN="7d"

# Google OAuth 2.0 credentials (Google Cloud Console → APIs & Services →
# Credentials). The authorized redirect URI must match GOOGLE_CALLBACK_URL.
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
GOOGLE_CALLBACK_URL="http://localhost:4000/api/v1/auth/google/callback"

# Frontend origin — CORS allow-list and post-login redirect target.
ALLOWED_ORIGIN="http://localhost:3000"
