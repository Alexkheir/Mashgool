# .env.prod.example — documents /opt/mashgool/.env.prod on the production VPS.
#
# You normally never create this file by hand: the deploy job in
# .github/workflows/deploy.yml regenerates it from GitHub secrets/variables on
# every deploy. It's documented here for the initial VPS bootstrap and for
# disaster recovery.

# GHCR image coordinates (owner must be lowercase)
GHCR_OWNER=alexkheir
# Git commit SHA (short) of the images to run; set by CI. For a rollback, set
# this to the last good SHA and re-run compose (see docs/deployment.md).
IMAGE_TAG=latest

# Public domain (no scheme), e.g. mashgool.duckdns.org
DOMAIN=your-domain.example

# Production database (db container). DATABASE_URL is derived from these in
# docker-compose.prod.yml — no separate value to keep in sync.
POSTGRES_DB=mashgool
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me

# ─── Auth (Feature 7) ────────────────────────────────────────────────────────
# Session JWT signing secret — must be >= 32 chars. Generate a fresh one for
# production (never the dev value): `openssl rand -base64 48`.
JWT_SECRET=change-me-to-a-long-random-string
# JWT_EXPIRES_IN defaults to 7d in docker-compose.prod.yml — override only if
# you need a different session lifetime.

# Google OAuth 2.0 credentials (Google Cloud Console). The callback URL is
# derived from DOMAIN in docker-compose.prod.yml
# (https://${DOMAIN}/api/v1/auth/google/callback) — register that exact URI in
# the Console. No GOOGLE_CALLBACK_URL entry needed here.
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
